<?xml version="1.0" encoding="utf-8"?>
<!--
  ES: Overlay SOLO para builds de DEBUG: permite HTTP plano para poder hablar
      con un BTCPay Server local (Docker en regtest, sin TLS, p. ej.
      http://192.168.x.x:14142). Este archivo reemplaza al de src/main/ cuando
      compilas la variante debug. Los APK de release usan el de src/main/
      (solo HTTPS).
  EN: DEBUG-only overlay: allows plain HTTP so the app can talk to a local
      BTCPay Server (Docker on regtest, no TLS, e.g. http://192.168.x.x:14142).
      This file shadows the one in src/main/ when building the debug variant.
      Release APKs use the src/main/ one (HTTPS only).
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
