<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical">

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp">

        <FrameLayout
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_logo_circle">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="⚡"
                android:textSize="20sp" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="@string/app_name"
                android:textColor="@color/neon_green"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="@string/label_lightning_payments"
                android:textColor="@color/text_secondary"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Screen title -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="20dp"
        android:paddingBottom="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text="@string/title_cobros"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:fontFamily="monospace"
            android:text="@string/subtitle_cobros"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Live BTC price ticker -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:fontFamily="monospace"
            android:text="₿"
            android:textColor="@color/neon_green"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="monospace"
            android:text="@string/label_btc_price"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvLivePrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text="@string/label_price_loading"
            android:textColor="@color/neon_green"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:fontFamily="monospace"
            android:text="@string/label_price_live"
            android:textColor="@color/neon_green"
            android:textSize="9sp" />
    </LinearLayout>

    <!-- Content area: form + payment-received overlay stacked -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- Scrollable form content -->
        <ScrollView
            android:id="@+id/scrollViewForm"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Cobro mixto info (F10) -->
                <TextView
                    android:id="@+id/tvMixedInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/bg_wallet_card"
                    android:fontFamily="monospace"
                    android:lineSpacingExtra="2dp"
                    android:padding="12dp"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:visibility="gone" />

                <!-- Amount input -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilAmount"
                    style="@style/Widget.CyberPOS.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:hint="@string/hint_amount"
                    app:prefixText="$ "
                    app:prefixTextColor="@color/neon_green">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etAmount"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:textColor="@color/text_primary"
                        android:textSize="24sp" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- BTC equivalent of entered USD amount -->
                <TextView
                    android:id="@+id/tvBtcEquivalent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="-4dp"
                    android:layout_marginBottom="16dp"
                    android:fontFamily="monospace"
                    android:text="≈ — BTC"
                    android:textColor="@color/neon_green"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <!-- Description input -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilDescription"
                    style="@style/Widget.CyberPOS.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:hint="@string/hint_description">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:textColor="@color/text_primary" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Generate QR button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGenerateQr"
                    style="@style/Widget.CyberPOS.Button.Primary"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="32dp"
                    android:text="@string/btn_generate_qr" />

                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:indeterminateTint="@color/neon_green"
                    android:visibility="gone" />

                <!-- QR code image -->
                <ImageView
                    android:id="@+id/ivQrCode"
                    android:layout_width="280dp"
                    android:layout_height="280dp"
                    android:layout_marginTop="8dp"
                    android:background="@color/surface"
                    android:contentDescription="@string/cd_qr_code"
                    android:padding="12dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvQrInstructions"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:text="@string/qr_waiting"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:visibility="gone" />

                <!-- NFC indicator — visible only when HCE is active -->
                <LinearLayout
                    android:id="@+id/layoutNfcBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_wallet_card"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="7dp"
                    android:visibility="gone">

                    <View
                        android:id="@+id/viewNfcDot"
                        android:layout_width="7dp"
                        android:layout_height="7dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_logo_circle" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:text="@string/label_nfc_active"
                        android:textColor="@color/neon_green"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>
        </ScrollView>

        <!-- PAGO RECIBIDO overlay — shown when BTCPay status becomes Settled -->
        <LinearLayout
            android:id="@+id/layoutPaymentSuccess"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/background"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="32dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="✓"
                android:textColor="@color/neon_green"
                android:textSize="80sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="monospace"
                android:gravity="center"
                android:text="@string/label_payment_received"
                android:textColor="@color/neon_green"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="monospace"
                android:gravity="center"
                android:text="@string/label_payment_received_subtitle"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPrintReceipt"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="48dp"
                android:fontFamily="monospace"
                android:text="@string/btn_print_receipt"
                android:textSize="14sp"
                app:cornerRadius="4dp"
                app:strokeColor="@color/neon_green"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnShareReceipt"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:fontFamily="monospace"
                android:text="@string/btn_share_receipt"
                android:textSize="14sp"
                app:cornerRadius="4dp"
                app:strokeColor="@color/neon_green"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveReceipt"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:fontFamily="monospace"
                android:text="@string/btn_save_receipt"
                android:textSize="14sp"
                app:cornerRadius="4dp"
                app:strokeColor="@color/neon_green"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNewPayment"
                style="@style/Widget.CyberPOS.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:text="@string/btn_new_payment_reset" />

        </LinearLayout>

    </FrameLayout>

    <!-- Bottom navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        app:itemIconTint="@color/bottom_nav_color"
        app:itemTextColor="@color/bottom_nav_color"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav_merchant" />

</LinearLayout>
