<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical">

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp">

        <FrameLayout
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_logo_circle">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="⚡"
                android:textSize="20sp" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="@string/app_name"
                android:textColor="@color/neon_green"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="@string/label_lightning_payments"
                android:textColor="@color/text_secondary"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- PAGAR A TIENDA banner -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface_variant"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="10dp"
            android:text="🏪"
            android:textSize="22sp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="@string/label_pay_store"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="@string/label_bitcoin_lightning"
                android:textColor="@color/text_secondary"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <!--
        FrameLayout lets the two payment overlays (layoutPaymentConfirm and
        layoutPaymentSent) stack on top of the normal scan/pay UI — including
        the PAGAR AHORA button — without needing a separate Activity.
    -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- ── Normal scan / pay UI ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:fillViewport="false">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Monto en BTC/USD + precio live — oculto hasta detectar un invoice
                         válido (escaneado) o mientras se usa la pestaña de monto manual -->
                    <LinearLayout
                        android:id="@+id/layoutScanAmountHeader"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <!-- BTC amount display -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:layout_marginTop="8dp"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/tvBtcAmount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="monospace"
                                android:text="@string/label_btc_amount"
                                android:textColor="@color/neon_green"
                                android:textSize="36sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:fontFamily="monospace"
                                android:text="BTC"
                                android:textColor="@color/neon_green"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvUsdEquivalent"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:layout_marginBottom="16dp"
                            android:fontFamily="monospace"
                            android:text="@string/label_usd_equivalent"
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp" />

                        <!-- Live BTC price chip -->
                        <TextView
                            android:id="@+id/tvLivePrice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:background="@drawable/bg_badge"
                            android:fontFamily="monospace"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="3dp"
                            android:text="@string/label_price_loading"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp" />

                    </LinearLayout>

                    <!-- QR Scanner view -->
                    <FrameLayout
                        android:id="@+id/layoutScan"
                        android:layout_width="260dp"
                        android:layout_height="260dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginBottom="8dp">

                        <com.journeyapps.barcodescanner.DecoratedBarcodeView
                            android:id="@+id/barcodeView"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent" />

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_gravity="top|start"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_corner_tl" />

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_gravity="top|end"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_corner_tr" />

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_gravity="bottom|start"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_corner_bl" />

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_gravity="bottom|end"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_corner_br" />

                        <!-- Camera permission denied placeholder -->
                        <LinearLayout
                            android:id="@+id/layoutPermissionDenied"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@color/surface_variant"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="16dp"
                            android:visibility="gone">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="📷"
                                android:textSize="36sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:fontFamily="monospace"
                                android:gravity="center"
                                android:text="@string/label_camera_permission"
                                android:textColor="@color/text_primary"
                                android:textSize="12sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:fontFamily="monospace"
                                android:gravity="center"
                                android:text="@string/msg_camera_needed"
                                android:textColor="@color/text_secondary"
                                android:textSize="10sp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnOpenSettings"
                                style="@style/Widget.CyberPOS.Button.Outline"
                                android:layout_width="wrap_content"
                                android:layout_height="36dp"
                                android:layout_marginTop="12dp"
                                android:fontFamily="monospace"
                                android:paddingHorizontal="16dp"
                                android:text="@string/btn_open_settings"
                                android:textSize="11sp" />
                        </LinearLayout>

                    </FrameLayout>

                    <!-- Invoice details panel (shown after successful QR scan) -->
                    <LinearLayout
                        android:id="@+id/layoutInvoiceDetails"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:background="@drawable/bg_wallet_card"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:visibility="gone">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="12dp"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/tvInvoiceTypeLabel"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:fontFamily="monospace"
                                android:text="@string/label_invoice_valid"
                                android:textColor="@color/neon_green"
                                android:textSize="11sp"
                                android:textStyle="bold" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnScanAgain"
                                style="@style/Widget.CyberPOS.Button.Outline"
                                android:layout_width="wrap_content"
                                android:layout_height="32dp"
                                android:fontFamily="monospace"
                                android:paddingHorizontal="12dp"
                                android:text="@string/btn_scan_again"
                                android:textSize="10sp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvInvoiceId"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:ellipsize="middle"
                            android:fontFamily="monospace"
                            android:maxLines="1"
                            android:textColor="@color/text_secondary"
                            android:textSize="9sp" />

                        <!-- F12: Perfil del negocio, visible antes de pagar -->
                        <TextView
                            android:id="@+id/btnViewMerchantProfile"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:background="?android:attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true"
                            android:fontFamily="monospace"
                            android:padding="4dp"
                            android:text="@string/btn_view_merchant_profile"
                            android:textColor="@color/neon_green"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:visibility="gone" />

                    </LinearLayout>

                    <!-- Lightning Network label -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="16dp"
                        android:background="@drawable/bg_badge"
                        android:fontFamily="monospace"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="4dp"
                        android:text="@string/label_lightning_network"
                        android:textColor="@color/neon_green"
                        android:textSize="11sp" />

                </LinearLayout>
            </androidx.core.widget.NestedScrollView>

            <!-- PAGAR AHORA / ABRIR WALLET button — anchored below scroll, covered by overlays -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPayNow"
                style="@style/Widget.CyberPOS.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="8dp"
                android:text="@string/btn_pay_now"
                android:textSize="16sp" />

            <!-- Cancelar — visible solo tras detectar un invoice escaneado -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancelScan"
                style="@style/Widget.CyberPOS.Button.Outline"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:text="@string/btn_cancel_payment"
                android:textSize="13sp"
                android:visibility="gone" />

        </LinearLayout>

        <!-- ── Payment waiting overlay ─────────────────────────────────────
             Shown after PAGAR AHORA: wallet is opened, app polls BTCPay. -->
        <LinearLayout
            android:id="@+id/layoutPaymentConfirm"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/background"
            android:orientation="vertical"
            android:visibility="gone">

            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:fillViewport="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <!-- ESPERANDO PAGO badge -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="16dp"
                        android:background="@drawable/bg_badge"
                        android:fontFamily="monospace"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="3dp"
                        android:text="ESPERANDO PAGO"
                        android:textColor="@color/neon_green"
                        android:textSize="10sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:fontFamily="monospace"
                        android:text="Confirmar pago"
                        android:textColor="@color/text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvConfirmBtcAmount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="monospace"
                        android:text="0.00000000 BTC"
                        android:textColor="@color/neon_green"
                        android:textSize="30sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvConfirmUsd"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="24dp"
                        android:fontFamily="monospace"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />

                    <!-- Waiting status card -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/bg_wallet_card"
                        android:gravity="center_horizontal"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <ProgressBar
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:indeterminate="true"
                            android:indeterminateTint="@color/neon_green"
                            style="?android:attr/progressBarStyleHorizontal" />

                        <TextView
                            android:id="@+id/tvPaymentStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:gravity="center"
                            android:text="Esperando confirmación de pago..."
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp" />

                    </LinearLayout>

                    <!-- Info tip card -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_wallet_card"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="6dp"
                            android:fontFamily="monospace"
                            android:text="💡 CÓMO PAGAR"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:lineSpacingMultiplier="1.4"
                            android:text="Tu wallet Bitcoin se abrirá automáticamente para completar el pago. La app detectará la confirmación en cuanto el pago sea procesado."
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />

                    </LinearLayout>

                </LinearLayout>
            </androidx.core.widget.NestedScrollView>

            <!-- Abrir wallet button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConfirmTestPayment"
                style="@style/Widget.CyberPOS.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="8dp"
                android:text="Abrir wallet"
                android:textSize="13sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancelPayment"
                style="@style/Widget.CyberPOS.Button.Outline"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:text="@string/btn_cancel_payment"
                android:textSize="13sp" />

        </LinearLayout>

        <!-- ── Payment sent overlay ──────────────────────────────────────
             Shown when BTCPay invoice status becomes "Settled".        -->
        <LinearLayout
            android:id="@+id/layoutPaymentSent"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/background"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="32dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="✓"
                android:textColor="@color/neon_green"
                android:textSize="80sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="monospace"
                android:gravity="center"
                android:text="@string/label_payment_sent"
                android:textColor="@color/neon_green"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="monospace"
                android:gravity="center"
                android:text="@string/label_payment_sent_subtitle"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRateBusiness"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="48dp"
                android:fontFamily="monospace"
                android:text="@string/btn_rate_business"
                android:textSize="14sp"
                android:visibility="gone"
                app:cornerRadius="4dp"
                app:strokeColor="@color/neon_green"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNewScan"
                style="@style/Widget.CyberPOS.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="10dp"
                android:text="@string/btn_new_scan" />

        </LinearLayout>

    </FrameLayout>

    <!-- Bottom navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        app:itemIconTint="@color/bottom_nav_color"
        app:itemTextColor="@color/bottom_nav_color"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav_customer" />

</LinearLayout>
