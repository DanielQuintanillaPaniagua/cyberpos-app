<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <!-- Bluetooth printing — legacy (API 26-30) -->
    <uses-permission
        android:name="android.permission.BLUETOOTH"
        android:maxSdkVersion="30" />
    <uses-permission
        android:name="android.permission.BLUETOOTH_ADMIN"
        android:maxSdkVersion="30" />
    <!-- Bluetooth printing — modern (API 31+) -->
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-permission
        android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation" />
    <!-- NFC tap-to-pay (HCE) -->
    <uses-permission android:name="android.permission.NFC" />
    <!-- 2FA SMS delivery -->
    <uses-permission android:name="android.permission.SEND_SMS" />
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />
    <uses-feature android:name="android.hardware.nfc.hce" android:required="false" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <application
        android:name=".CyberPOSApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.CyberPOS"
        android:networkSecurityConfig="@xml/network_security_config"
        android:usesCleartextTraffic="true"
        android:localeConfig="@xml/locales_config">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".LoginActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".RegisterActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".HomeActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".PaymentActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".CustomerHomeActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".HistorialActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".AjustesActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".MerchantHistorialActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".MerchantAjustesActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".InformacionNegocioActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".CuentasBancariasActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ImpuestosTarifasActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".PuntosLealtadActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".NotificacionesMerchantActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".PantallaCobroActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".MerchantMonedaActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ConfirmacionesActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".PinSeguridadActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".DosFaActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".DispositivosVinculadosActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".AyudaContactoActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".IdiomaActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".CustomerPerfilActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".CustomerMonedaActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".CustomerPinActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".CustomerBiometriaActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".CustomerNotificacionesActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".CustomerVersionActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ReportesActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".BluetoothPrinterActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".CatalogoActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".GestionProductosActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".DashboardActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".TwoFactorActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />

        <!-- NFC HCE service — emulates NFC Type 4 Tag while invoice QR is shown -->
        <service
            android:name=".NfcHceService"
            android:exported="true"
            android:permission="android.permission.BIND_NFC_SERVICE">
            <intent-filter>
                <action android:name="android.nfc.cardemulation.action.HOST_APDU_SERVICE" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <meta-data
                android:name="android.nfc.cardemulation.host_apdu_service"
                android:resource="@xml/apduservice" />
        </service>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="com.cyberpos.app.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
